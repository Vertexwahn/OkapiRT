    ],
    data = ["//flatland/scenes"],
    deps = [
        "//flatland/rendering/scene:load_scene",
        "//flatland/rendering/scene/shape",
        "//flatland/rendering/scene/shape:medium_event",
        "@googletest//:gtest_main",
    ],
)

