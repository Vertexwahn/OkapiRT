    name = "moeller_trumbore",
    hdrs = ["moeller_trumbore.h"],
    deps = [
        "//math:point",
        "//math:ray",
    ],
)


cc_library(
    name = "sphere",
    hdrs = ["sphere.h"],
    deps = ["//flatland/rendering/scene/shape"],
)

cc_test(
    name = "sphere_test",
    size = "small",
    srcs = [
        "sphere_test.cpp",
    ],
    deps = [
        ":sphere",
        "//okapi/rendering/scene:load_scene",
        "@googletest//:gtest_main",
    ],
)

cc_library(
    name = "triangle_mesh",
